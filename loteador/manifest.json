{
  "server": {
    "request": "https://server.panax.io/request.asp",
    "login": "",
    "download": "https://server.panax.io/download.asp"
  },
  "state": { "desarrollo": "${xo.site.seed.replace(/^#/,'')}" },
  "session": {
    "gist": "https://gist.githubusercontent.com/uriel-online/672d8d6e6e2898136ae3e84d9b54443b/raw/neibora-server",
    "referer_id": "${location.host + location.pathname.split('/',2).join('/')}"
  },
  "sources": {
    "^#(.+)$": "${xover.session.server}/repository/$1/lotes.xml",
    "^#(.+)_(.+)$": "${xover.session.server}/repository/$1/$2.xml",
    "^#(.+)_extraordinarias$": "${xover.session.server}/repository/$1/extraordinarias_internas.xml",
    "^#(.+)_extraordinarias_externas$": "${xover.session.server}/repository/$1/extraordinarias_externas.xml",
    "^#(peninsula)$": {
      "server:download": {
        "file": "${xover.session.server}/repository/$1/lotes.xml",
        "^authorization": "${xover.session.encodeCredential(xover.session.user_login, xover.session.id_token) || ''}",
        "^x-referer-id": "${xover.session.referer_id || ''}"
      }
    },
    "^#(.+):map$": "../assets/desarrollos/$1/loteador.map",
    "^#(.+):settings$": "../assets/desarrollos/$1/loteador_settings.xml",
    "^#(.+)_servicios:settings$": "../assets/desarrollos/$1/servicios_settings.xml",
    "^#(.+)_estacionamiento:settings$": "../assets/desarrollos/$1/estacionamiento_settings.xml",
    "^#(.+)_extraordinarias:settings$": "../assets/desarrollos/$1/loteador_settings.xml",
    "^#(.+)_extraordinarias_externas:settings$": "../assets/desarrollos/$1/loteador_settings.xml",
    "^px-(.+)": "../components/$1.xhtml",
    "#login": "login.xml"
  },
   "start": [
      "#ws",
      "px-loteador",
      { "updateTunnel": [] }
   ],
  "settings": {
    "^#(.+)$": {
      "headers": {
        "cache": "no-store",
        "Cache-Control": "no-cache"
      }
    },
    ".resx": {
      "headers": {
        "cache": "no-store",
        "Cache-Control": "no-cache"
      }
    }
  }
}